[configuration]
entry_symbol = "zappy_gui_library_init"
compatibility_minimum = "4.1"
reloadable = true

[libraries]
linux.debug.x86_64 = "res://bin/libzappy_gui.linux.debug.x86_64.so"
linux.release.x86_64 = "res://bin/libzappy_gui.linux.release.x86_64.so"
windows.debug.x86_64 = "res://bin/libzappy_gui.windows.debug.x86_64.dll"
windows.release.x86_64 = "res://bin/libzappy_gui.windows.release.x86_64.dll"
