{
	"version": 6,
	"cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
	"configurePresets": [
		{
			"name": "linux-debug",
			"displayName": "Linux x86_64 (Debug)",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/linux-debug",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "linux-release",
			"displayName": "Linux x86_64 (Release)",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/linux-release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "windows-debug",
			"displayName": "Windows x86_64 (Debug, mingw cross-compile)",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/windows-debug",
			"toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "windows-release",
			"displayName": "Windows x86_64 (Release, mingw cross-compile)",
			"generator": "Ninja",
			"binaryDir": "${sourceDir}/build/windows-release",
			"toolchainFile": "${sourceDir}/cmake/toolchain-mingw64.cmake",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		}
	],
	"buildPresets": [
		{ "name": "linux-debug", "configurePreset": "linux-debug" },
		{ "name": "linux-release", "configurePreset": "linux-release" },
		{ "name": "windows-debug", "configurePreset": "windows-debug" },
		{ "name": "windows-release", "configurePreset": "windows-release" }
	]
}
